{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch . --ext js,jsx,ts,tsx,json,css --exec next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,md}\""
  },
  "dependencies": {
    "@heroicons/react": "^2.1.5",
    "framer-motion": "^12.42.2",
    "next": "^16.2.9",
    "react": "^18.2.1",
    "react-animated-numbers": "^0.18.0",
    "react-dom": "^18.2.1",
    "react-type-animation": "^3.2.0",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "nodemon": "^3.1.14",
    "postcss": "^8",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.1"
  }
}
